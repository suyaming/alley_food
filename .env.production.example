# Production env file. Copy to .env.production on the VPS and fill in real values.
# Do NOT commit the real .env.production — only this *.example file is in git.

# ─── Domain (used by Caddy for the auto-HTTPS reverse proxy) ────────────
DOMAIN=shop.example.com

# ─── Site URLs ──────────────────────────────────────────────────────────
NUXT_SITE_URL=https://shop.example.com
NUXT_PUBLIC_SITE_URL=https://shop.example.com

# ─── PayPal LIVE credentials ────────────────────────────────────────────
# Switch from sandbox once you've completed end-to-end testing.
NUXT_PAYPAL_ENV=live
NUXT_PAYPAL_CLIENT_ID=
NUXT_PAYPAL_CLIENT_SECRET=
NUXT_PAYPAL_WEBHOOK_ID=
NUXT_PUBLIC_PAYPAL_CLIENT_ID=
NUXT_PUBLIC_PAYPAL_CURRENCY=USD

# ─── Resend (transactional email) ───────────────────────────────────────
# https://resend.com — verify your domain first, then create an API key.
NUXT_RESEND_API_KEY=
NUXT_MAIL_FROM_ADDRESS=hello@your-domain.com
NUXT_MAIL_FROM_NAME=Alley Shop
NUXT_MAIL_KITCHEN_ADDRESS=kitchen@your-domain.com

# ─── Database (SQLite, persisted via docker volume ./data:/app/data) ────
DATABASE_URL=/app/data/orders.db

# ─── Admin panel ────────────────────────────────────────────────────────
NUXT_ADMIN_PASSWORD=change-me-to-a-long-random-string
NUXT_ADMIN_SESSION_SECRET=change-me-to-a-different-long-random-string

# ─── Analytics (self-hosted Umami) ──────────────────────────────────────
# Set after Umami is up at https://shop.example.com/umami and a website is created.
NUXT_PUBLIC_UMAMI_HOST=https://shop.example.com/umami
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# Umami app secrets (used by the umami container itself, not the Nuxt app).
UMAMI_APP_SECRET=change-me-to-a-32-char-random-string
UMAMI_DB_PASSWORD=change-me-to-a-strong-postgres-password

# ─── Sentry ─────────────────────────────────────────────────────────────
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Optional: source-map upload at build time
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
