{$DOMAIN:shop.example.com} {
    encode zstd gzip

    # Umami self-hosted analytics dashboard + tracker script + collect endpoint.
    # Mount under /umami so we don't need a separate subdomain.
    @umami path /umami /umami/*
    handle @umami {
        reverse_proxy umami:3000
    }

    # IPX-transformed images (immutable, content-hashed by query string)
    @ipx path /_ipx/*
    handle @ipx {
        header Cache-Control "public, max-age=2592000, immutable"
        reverse_proxy app:3000
    }

    # Static product / brand assets — long cache
    @assets path /products/* /mockups/* /logos/* /og/* /favicon.* /_nuxt/*
    handle @assets {
        header Cache-Control "public, max-age=31536000, immutable"
        reverse_proxy app:3000
    }

    # Block access to internal admin paths from search engines and prevent caching
    @admin path /admin* /api/admin/*
    handle @admin {
        header Cache-Control "no-store"
        reverse_proxy app:3000
    }

    # Default: pass-through to Nuxt app, no aggressive cache (HTML may change)
    handle {
        header Cache-Control "public, max-age=0, must-revalidate"
        reverse_proxy app:3000
    }

    # Security baseline (Phase 3.5 will tighten via nuxt-security at app layer)
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # HSTS: 1 year, subdomains, preload-ready (only enable once you have SSL working)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}
