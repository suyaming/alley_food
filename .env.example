# ─── PayPal ─────────────────────────────────────────────────────────────
# Get sandbox creds from https://developer.paypal.com/dashboard/applications/sandbox
# For live, register an app under "Live" and switch NUXT_PAYPAL_ENV=live.

NUXT_PAYPAL_CLIENT_ID=
NUXT_PAYPAL_CLIENT_SECRET=
NUXT_PAYPAL_ENV=sandbox

# Webhook ID. Created in the PayPal app dashboard once the public URL is live.
# Subscribe at minimum to:
#   PAYMENT.CAPTURE.COMPLETED
#   PAYMENT.CAPTURE.REFUNDED
#   PAYMENT.CAPTURE.REVERSED
#   PAYMENT.CAPTURE.DENIED
#   CUSTOMER.DISPUTE.CREATED
NUXT_PAYPAL_WEBHOOK_ID=

# Public client id (exposed to browser; safe to commit if you wanted to).
NUXT_PUBLIC_PAYPAL_CLIENT_ID=
NUXT_PUBLIC_PAYPAL_CURRENCY=USD
# Drives UI copy ('sandbox demo' vs. 'encrypted at the payment processor'). Set to 'live' in prod.
NUXT_PUBLIC_PAYPAL_ENV=sandbox

# ─── Site ───────────────────────────────────────────────────────────────
# Used by mail templates, sitemap, OG tags. No trailing slash.
NUXT_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (transactional email) ───────────────────────────────────────
# https://resend.com — free tier: 3000 emails/month, 100/day.
# Required for transactional emails (order confirmation, kitchen alert, refund).
# Get an API key at https://resend.com/api-keys (must verify your sending domain first).

NUXT_RESEND_API_KEY=

NUXT_MAIL_FROM_ADDRESS=hello@your-domain.com
NUXT_MAIL_FROM_NAME=Alley Shop
NUXT_MAIL_KITCHEN_ADDRESS=kitchen@your-domain.com

# ─── Database ───────────────────────────────────────────────────────────
# SQLite file path (absolute or relative to cwd). Default ./data/orders.db.
DATABASE_URL=./data/orders.db

# ─── Admin panel (/admin) ───────────────────────────────────────────────
# Password for the kitchen / operator dashboard.
NUXT_ADMIN_PASSWORD=change-me
# Random 32+ char string used to sign session cookies.
NUXT_ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# ─── Analytics (self-hosted Umami) ──────────────────────────────────────
# Leave blank in development to disable tracking entirely.
NUXT_PUBLIC_UMAMI_HOST=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# ─── Sentry error monitoring ────────────────────────────────────────────
# Leave blank in development. Free tier covers 5k events/month.
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ─── OpenRouter (only for scripts/gen-product-images.mjs, not runtime) ──
OPENROUTER_API_KEY=
